# CopperHead Bot Configuration
# Copy this file to .env and customize

# WebSocket URL of the CopperHead server
COPPERHEAD_SERVER_URL=ws://localhost:8765/ws/

# Display name for your bot (shown in tournament)
BOT_NAME=CopperheadChampion

# Internal difficulty level 1-10 (affects error simulation, 10=perfect play)
BOT_DIFFICULTY=10

# Set to true to suppress console output
BOT_QUIET=false
